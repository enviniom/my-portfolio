---
import Section from "../Section.astro";
const { summary, title, highlights = [] } = Astro.props;
---

<Section title={title}>
	<p>{summary}</p>
	{
		highlights.length > 0 && (
			<ul>
				{highlights.map((item: string) => <li>{item}</li>)}
			</ul>
		)
	}
</Section>

<style>
	p {
		margin-bottom: 1.5rem;
		color: #333;
		line-height: 1.6;
	}

	ul {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-left: 1.5rem;
		margin: 0;
		list-style-type: disc;
	}

	li {
		color: #444;
		font-size: 0.85rem;
		font-style: oblique;
		line-height: 1;
	}
</style>
